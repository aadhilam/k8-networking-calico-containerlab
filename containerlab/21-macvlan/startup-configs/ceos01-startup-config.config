! Arista cEOS startup configuration
!
hostname ceos
!
! Define VLAN 10 (for Calico pod networking)
!
vlan 10
   name Calico-Network
!
! Define VLAN 20 (for macvlan)
!
vlan 20
   name Macvlan-Network
!
! Configure interfaces for VLAN 10 (Calico pod network)
!
interface Ethernet1
   description Connection to k01-control-plane (VLAN 10)
   switchport mode access
   switchport access vlan 10
!
interface Ethernet2
   description Connection to k01-worker (VLAN 10)
   switchport mode access
   switchport access vlan 10
!
interface Ethernet3
   description Connection to k01-worker2 (VLAN 10)
   switchport mode access
   switchport access vlan 10
!
! Configure interfaces for VLAN 20 (macvlan)
!
interface Ethernet4
   description Connection to k01-control-plane (VLAN 20)
   switchport mode access
   switchport access vlan 20
!
interface Ethernet5
   description Connection to k01-worker (VLAN 20)
   switchport mode access
   switchport access vlan 20
!
interface Ethernet6
   description Connection to k01-worker2 (VLAN 20)
   switchport mode access
   switchport access vlan 20
!
! Layer 3 interface for VLAN 10
!
interface Vlan10
   description Calico Network L3 Interface
   ip address 10.10.10.1/24
!
! Layer 3 interface for VLAN 20
!
interface Vlan20
   description Macvlan Network L3 Interface
   ip address 10.10.20.1/24
!
! Enable IP routing
!
ip routing
!
! Management interface
!
interface Management0
   ip address dhcp
   no shutdown
!
! User configuration
!
username admin privilege 15 secret admin
!
! Enable HTTP API
!
management api http-commands
   no shutdown
!
! Note: BGP configuration is optional and not required for this macvlan lab.
! The switch is configured for basic Layer 2/3 connectivity.
!

end
