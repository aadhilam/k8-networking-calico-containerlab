! Arista cEOS startup configuration for Ingress TLS Lab
!
hostname ceos
!
! Define VLAN 10 for Kubernetes Network
!
vlan 10
   name Kubernetes-Network
!
! Define VLAN 30 for External User Network
!
vlan 30
   name External-User-Network
!
! Configure interfaces as access ports in VLAN 10 (Kubernetes nodes)
! Only worker and worker2 have BGP peering (Ingress Gateway nodes)
!
interface Ethernet1
   description Connection to k01-control-plane
   switchport mode access
   switchport access vlan 10
!
interface Ethernet2
   description Connection to k01-worker (BGP Peer / Ingress Gateway)
   switchport mode access
   switchport access vlan 10
!
interface Ethernet3
   description Connection to k01-worker2 (BGP Peer / Ingress Gateway)
   switchport mode access
   switchport access vlan 10
!
interface Ethernet4
   description Connection to k01-worker3
   switchport mode access
   switchport access vlan 10
!
interface Ethernet5
   description Connection to k01-worker4
   switchport mode access
   switchport access vlan 10
!
! Configure interface in VLAN 30 for external user
!
interface Ethernet6
   description Connection to External User Host
   switchport mode access
   switchport access vlan 30
!
! Layer 3 interface for VLAN 10 (Kubernetes Network)
!
interface Vlan10
   description Kubernetes Network L3 Interface
   ip address 10.10.10.1/24
!
! Layer 3 interface for VLAN 30 (External User Network)
!
interface Vlan30
   description External User Network L3 Interface
   ip address 10.30.30.1/24
!
! Enable IP routing
!
ip routing
!
! Management interface
!
interface Management0
   ip address dhcp
   no shutdown
!
! User configuration
!
username admin privilege 15 secret admin
!
! Enable HTTP API
!
management api http-commands
   no shutdown

! BGP Configuration
! Note: The ToR accepts BGP connections from the entire subnet, but only nodes
! with the bgp-peer=true label (configured via Calico's nodeSelector) will 
! actually initiate BGP sessions. This is selective peering controlled by Calico.
! 
! The BGP speaker nodes (worker, worker2) will advertise LoadBalancer IPs
! for the Ingress Gateway to the ToR, making services accessible from VLAN 30.
router bgp 65001
   router-id 10.10.10.1
   bgp listen range 10.10.10.0/24 peer-group CALICO-K8S remote-as 65010
   neighbor CALICO-K8S peer group
   neighbor CALICO-K8S remote-as 65010
   neighbor CALICO-K8S description "Calico Kubernetes Nodes"
   !
   ! Enable ECMP for load balancing across gateway nodes
   maximum-paths 4
   !
   address-family ipv4
      neighbor CALICO-K8S activate
      network 10.10.10.0/24
      network 10.30.30.0/24

end

