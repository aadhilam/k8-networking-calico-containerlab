! Arista cEOS startup configuration for Calico DSCP Lab
! This configuration demonstrates DSCP-based traffic classification and rate limiting
!
hostname ceos
!
! Define VLAN 10 for Kubernetes Network
!
vlan 10
   name Kubernetes-Network
!
! Define VLAN 30 for External Client Network
!
vlan 30
   name External-Client-Network
!
! Configure interfaces as access ports in VLAN 10 (Kubernetes nodes)
!
interface Ethernet1
   description Connection to k01-control-plane
   switchport mode access
   switchport access vlan 10
!
! Convert Ethernet2 to routed port for DSCP-based QoS
! DSCP matching requires L3 interfaces, not L2 switchport interfaces
!
interface Ethernet2
   description Connection to k01-worker
   switchport mode access
   switchport access vlan 10
!
! Configure interface in VLAN 30 for external client
!
interface Ethernet3
   description Connection to External Client
   switchport mode access
   switchport access vlan 30
!
! Layer 3 interface for VLAN 10 (Kubernetes Network)
!
interface Vlan10
   description Kubernetes Network L3 Interface
   ip address 10.10.10.1/24
!
! Layer 3 interface for VLAN 30 (External Client Network)
!
interface Vlan30
   description External Client Network L3 Interface
   ip address 10.30.30.1/24
!
! Enable IP routing
!
ip routing
!
! ==============================================================================
! Note: DSCP-based QoS Throttling
! ==============================================================================
!
! The containerized Arista cEOS platform does not support DSCP matching
! in QoS class maps. Instead, DSCP-based throttling is performed by a
! Linux router node (router) using Linux tc (traffic control).
!
! The Linux router uses tc filters to match DSCP values:
! - DSCP AF11 (0x28 in TOS byte) -> 1 Mbps throttle
! - DSCP EF (0xb8 in TOS byte) -> 5 Mbps throttle
!
! Management interface
!
interface Management0
   ip address dhcp
   no shutdown
!
! User configuration
!
username admin privilege 15 secret admin
!
! Enable HTTP API for management
!
management api http-commands
   no shutdown
!
! BGP Configuration
! The ToR accepts BGP connections from nodes with bgp-peer=true label
! BGP-learned routes will replace static routes for pod network
!
router bgp 65001
   router-id 10.10.10.1
   bgp listen range 10.10.10.0/24 peer-group CALICO-K8S remote-as 65010
   neighbor CALICO-K8S peer group
   neighbor CALICO-K8S remote-as 65010
   neighbor CALICO-K8S description "Calico Kubernetes Nodes"
   !
   address-family ipv4
      neighbor CALICO-K8S activate
      network 10.10.10.0/24
      network 10.30.30.0/24
!
end
